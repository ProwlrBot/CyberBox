# CyberSandbox environment variables
# Copy to .env and fill in your values

# ── AI Backends ──────────────────────────────────────────────
# Claude (Anthropic API)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama (local inference)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# ── Git Identity ─────────────────────────────────────────────
GIT_NAME=
GIT_EMAIL=

# ── GitHub ───────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Harbinger ────────────────────────────────────────────────
HARBINGER_DIR=/home/hunter/.harbinger

# ── Plugin Manager ───────────────────────────────────────────
CSBX_HOME=/home/hunter/.csbx
CSBX_REGISTRY_URL=https://raw.githubusercontent.com/ProwlrBot/csbx-registry/main/registry.yaml

# ── Services ─────────────────────────────────────────────────
SEARXNG_URL=http://host.docker.internal:8888

# ── General ──────────────────────────────────────────────────
TZ=America/New_York
