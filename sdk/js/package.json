{
  "name": "@agent-infra/sandbox",
  "version": "1.0.13",
  "description": "Node.js SDK for AIO Sandbox integration providing tools and interfaces",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "rslib build && tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "dev": "tsc --watch",
    "clean": "rimraf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProwlrBot/CyberBox.git",
    "directory": "sdk/js"
  },
  "homepage": "https://github.com/ProwlrBot/CyberBox/tree/main/sdk/js#readme",
  "bugs": {
    "url": "https://github.com/ProwlrBot/CyberBox/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "aio",
    "sandbox",
    "cybersandbox",
    "cyberbox",
    "security",
    "sdk",
    "nodejs",
    "typescript"
  ],
  "author": "kdairatchi <prowlr@proton.me>",
  "license": "Apache-2.0",
  "devDependencies": {
    "@rslib/core": "^0.21.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
