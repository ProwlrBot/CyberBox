{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ssrf_chain",
  "type": "object",
  "additionalProperties": false,
  "required": ["primitive", "fetcher", "egress", "filters_observed", "bypass_techniques", "internal_targets", "chain", "stop_conditions"],
  "properties": {
    "primitive": { "type": "string", "minLength": 8, "maxLength": 400 },
    "fetcher": {
      "type": "string",
      "enum": ["browser", "server", "preview_image", "webhook", "pdf_renderer", "http_client_lib", "other"]
    },
    "egress": { "type": "string", "enum": ["blind", "reflected", "partial"] },
    "filters_observed": {
      "type": "array",
      "items": { "type": "string", "minLength": 2, "maxLength": 400 }
    },
    "bypass_techniques": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "evidence", "test_payload"],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "dns_rebinding", "decimal_ip", "octal_ip", "enclosed_alphanumerics",
              "cname_to_internal", "host_header_injection", "url_parser_confusion",
              "redirect_to_internal", "short_url_redirect", "userinfo_at",
              "file_scheme", "gopher_smuggle", "dict_scheme", "ipv6_zoneid"
            ]
          },
          "evidence": { "type": "string", "minLength": 4, "maxLength": 240 },
          "test_payload": { "type": "string", "minLength": 4, "maxLength": 400 }
        }
      }
    },
    "internal_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "url", "expected_signal"],
        "properties": {
          "service": {
            "type": "string",
            "enum": [
              "aws_imds", "gcp_metadata", "azure_imds",
              "kubernetes_api", "consul", "etcd", "redis", "memcached",
              "elasticsearch", "internal_admin", "cloud_storage", "other"
            ]
          },
          "url": { "type": "string", "minLength": 4, "maxLength": 400 },
          "expected_signal": { "type": "string", "minLength": 4, "maxLength": 240 }
        }
      }
    },
    "chain": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 6, "maxLength": 400 }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 6, "maxLength": 240 }
    }
  }
}
