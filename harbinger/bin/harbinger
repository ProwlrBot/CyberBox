#!/usr/bin/env bash
# harbinger — Autonomous bug bounty pipeline orchestrator
# Like Aperant but for hunting. Dual-LLM (Claude + Ollama).
#
# Usage:
#   harbinger hunt target.com
#   harbinger recon target.com
#   harbinger analyze request.txt
#   harbinger triage findings.json
#   harbinger report finding-42

set -euo pipefail

HARBINGER_DIR="${HARBINGER_DIR:-$HOME/.harbinger}"
HARBINGER_BIN="$(cd "$(dirname "$0")" && pwd)"

# ── Tunables (all overridable via env) ───────────────────────
HARBINGER_BEST_MODEL="${HARBINGER_BEST_MODEL:-opus}"
KATANA_SUBDOMAIN_LIMIT="${KATANA_SUBDOMAIN_LIMIT:-20}"
KATANA_DEPTH="${KATANA_DEPTH:-2}"
HARBINGER_TRIAGE_LIMIT="${HARBINGER_TRIAGE_LIMIT:-50}"
NUCLEI_SEVERITY="${NUCLEI_SEVERITY:-medium,high,critical}"
ARJUN_URL_LIMIT="${ARJUN_URL_LIMIT:-10}"
HARBINGER_VALIDATE_LIMIT="${HARBINGER_VALIDATE_LIMIT:-10}"
HARBINGER_VALIDATE_TIMEOUT="${HARBINGER_VALIDATE_TIMEOUT:-30}"
HARBINGER_SCOPE_WILDCARD="${HARBINGER_SCOPE_WILDCARD:-*.}"
OLLAMA_HOST_DEFAULT="${OLLAMA_HOST:-http://localhost:11434}"

# ── Colors (respect NO_COLOR) ────────────────────────────────
if [[ -n "${NO_COLOR:-}" ]] || [[ ! -t 1 ]]; then
  RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; DIM=''; BOLD=''; NC=''
else
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  CYAN='\033[0;36m'
  DIM='\033[0;90m'
  BOLD='\033[1m'
  NC='\033[0m'
fi

# ── Input validation ─────────────────────────────────────────
validate_target() {
  local t="$1"
  if [[ -z "$t" ]] || [[ "$t" =~ [[:space:]] ]] || [[ "$t" == *".."* ]] || [[ "$t" == /* ]]; then
    echo "Error: invalid target name: $t" >&2
    exit 1
  fi
  # Allow domains, IPs, simple hostnames
  if [[ ! "$t" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "Error: target must be alphanumeric with . _ -" >&2
    exit 1
  fi
}

log()  { echo -e "${DIM}[harbinger]${NC} $*"; }
info() { echo -e "${CYAN}[+]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[x]${NC} $*" >&2; }
ok()   { echo -e "${GREEN}[✓]${NC} $*"; }

# ── Init ─────────────────────────────────────────────────────
init_workspace() {
  local target="$1"
  validate_target "$target"
  local workspace="${HARBINGER_DIR}/targets/${target}"

  mkdir -p "${workspace}"/{recon,findings,evidence,reports,logs}

  # Generate target.json safely via jq (no shell injection, no quoting bugs)
  jq -n \
    --arg target "$target" \
    --arg created "$(date -Iseconds)" \
    --arg status "active" \
    --arg scope "${HARBINGER_SCOPE_WILDCARD}${target}" \
    '{target:$target, created:$created, status:$status, scope:[$scope], phases_completed:[]}' \
    > "${workspace}/target.json"

  echo "$workspace"
}

# ── AI Router ────────────────────────────────────────────────
# Use Ollama for fast/cheap tasks, Claude for complex reasoning
ai() {
  local tier="$1"
  shift

  case "$tier" in
    fast)
      # Ollama for parsing, classification, summarization
      "${HARBINGER_BIN}/invoke-ollama" -r "$@" 2>/dev/null
      ;;
    deep)
      # Claude for vuln analysis, exploit reasoning, report writing
      if [[ -n "${ANTHROPIC_API_KEY:-${CLAUDE_API_KEY:-}}" ]]; then
        "${HARBINGER_BIN}/invoke-claude" -r "$@" 2>/dev/null
      else
        warn "No Claude API key — falling back to Ollama"
        "${HARBINGER_BIN}/invoke-ollama" -r "$@" 2>/dev/null
      fi
      ;;
    best)
      # Claude Opus for the hardest reasoning tasks
      if [[ -n "${ANTHROPIC_API_KEY:-${CLAUDE_API_KEY:-}}" ]]; then
        "${HARBINGER_BIN}/invoke-claude" -r -m "$HARBINGER_BEST_MODEL" "$@" 2>/dev/null
      else
        "${HARBINGER_BIN}/invoke-ollama" -r "$@" 2>/dev/null
      fi
      ;;
  esac
}

# ── Phase: Recon ─────────────────────────────────────────────
phase_recon() {
  local target="$1"
  local workspace
  workspace=$(init_workspace "$target")

  info "Phase: RECON — ${target}"
  log "Workspace: ${workspace}"

  # Subdomain enumeration
  info "Enumerating subdomains..."
  if command -v subfinder &>/dev/null; then
    subfinder -d "$target" -silent 2>/dev/null | sort -u > "${workspace}/recon/subdomains.txt"
    local count
    count=$(wc -l < "${workspace}/recon/subdomains.txt")
    ok "Found ${count} subdomains"
  else
    warn "subfinder not found — skipping"
  fi

  # Probe live hosts
  if command -v httpx &>/dev/null && [[ -s "${workspace}/recon/subdomains.txt" ]]; then
    info "Probing live hosts..."
    httpx -l "${workspace}/recon/subdomains.txt" -silent -status-code -title -tech-detect \
      -json 2>/dev/null > "${workspace}/recon/live_hosts.json" || true
    local live
    live=$(wc -l < "${workspace}/recon/live_hosts.json")
    ok "Found ${live} live hosts"
  fi

  # URL discovery
  if command -v katana &>/dev/null && [[ -s "${workspace}/recon/subdomains.txt" ]]; then
    info "Crawling for URLs..."
    head -n "$KATANA_SUBDOMAIN_LIMIT" "${workspace}/recon/subdomains.txt" | \
      katana -silent -d "$KATANA_DEPTH" -jc 2>/dev/null | sort -u > "${workspace}/recon/urls.txt" || true
    local urls
    urls=$(wc -l < "${workspace}/recon/urls.txt")
    ok "Found ${urls} URLs"
  fi

  # Wayback URLs
  if command -v waybackurls &>/dev/null; then
    info "Fetching wayback URLs..."
    echo "$target" | waybackurls 2>/dev/null | sort -u > "${workspace}/recon/wayback.txt" || true
  fi

  # AI-powered triage of recon data (use Ollama — fast, local)
  if [[ -s "${workspace}/recon/live_hosts.json" ]]; then
    info "AI triaging recon data..."
    ai fast -s "You are a bug bounty recon analyst. Identify the most interesting targets for vulnerability testing." \
      "Triage these live hosts and rank by attack surface interest. Focus on: API endpoints, admin panels, file upload, auth pages, old tech stacks.

$(head -n "$HARBINGER_TRIAGE_LIMIT" "${workspace}/recon/live_hosts.json")" > "${workspace}/recon/triage.md" || true
    ok "Triage report: ${workspace}/recon/triage.md"
  fi

  # Log phase completion
  local target_json="${workspace}/target.json"
  jq '.phases_completed += ["recon"] | .last_recon = now' "$target_json" > "${target_json}.tmp" 2>/dev/null && \
    mv "${target_json}.tmp" "$target_json" || true

  ok "Recon complete — ${workspace}/recon/"
}

# ── Phase: Scan ──────────────────────────────────────────────
phase_scan() {
  local target="$1"
  local workspace="${HARBINGER_DIR}/targets/${target}"

  if [[ ! -d "$workspace" ]]; then
    err "No workspace for ${target}. Run: harbinger recon ${target}"
    exit 1
  fi

  info "Phase: SCAN — ${target}"

  # Nuclei scan on live hosts
  if command -v nuclei &>/dev/null && [[ -s "${workspace}/recon/live_hosts.json" ]]; then
    info "Running nuclei..."
    jq -r '.url // empty' "${workspace}/recon/live_hosts.json" | \
      nuclei -silent -severity "$NUCLEI_SEVERITY" -jsonl 2>/dev/null \
      > "${workspace}/findings/nuclei.jsonl" || true
    local findings
    findings=$(wc -l < "${workspace}/findings/nuclei.jsonl")
    ok "Nuclei: ${findings} findings"
  fi

  # Parameter discovery
  if command -v arjun &>/dev/null && [[ -s "${workspace}/recon/urls.txt" ]]; then
    info "Discovering parameters..."
    head -n "$ARJUN_URL_LIMIT" "${workspace}/recon/urls.txt" | while read -r url; do
      arjun -u "$url" --stable -oJ "${workspace}/findings/params_$(echo "$url" | md5sum | cut -c1-8).json" 2>/dev/null || true
    done
  fi

  ok "Scan complete — ${workspace}/findings/"
}

# ── Phase: Analyze ───────────────────────────────────────────
phase_analyze() {
  local input="$1"
  local workspace="${HARBINGER_DIR}/analysis"
  mkdir -p "$workspace"

  info "Phase: ANALYZE"

  local data
  if [[ -f "$input" ]]; then
    data=$(cat "$input")
  else
    data="$input"
  fi

  # Use Claude for deep analysis
  ai deep -s "You are an expert bug bounty hunter analyzing HTTP traffic. Be specific about vulnerability classes, CVSS scores, and reproduction steps." \
    "Analyze this for security vulnerabilities:

${data}"
}

# ── Phase: Report ────────────────────────────────────────────
phase_report() {
  local target="$1"
  local workspace="${HARBINGER_DIR}/targets/${target}"

  if [[ ! -d "$workspace" ]]; then
    err "No workspace for ${target}"
    exit 1
  fi

  info "Phase: REPORT — ${target}"

  local findings_data=""
  if [[ -s "${workspace}/findings/nuclei.jsonl" ]]; then
    findings_data=$(cat "${workspace}/findings/nuclei.jsonl")
  fi

  if [[ -z "$findings_data" ]]; then
    warn "No findings to report"
    exit 0
  fi

  # Use Claude Opus for report writing (needs best reasoning)
  ai best -s "You are a professional bug bounty report writer. Write clear, actionable reports with impact-first summaries. Use markdown format compatible with HackerOne/Bugcrowd." \
    "Generate a bug bounty report for these findings on ${target}. Group by severity, include reproduction steps, and assess real-world impact.

${findings_data}" > "${workspace}/reports/report-$(date +%Y%m%d).md"

  ok "Report: ${workspace}/reports/report-$(date +%Y%m%d).md"
}

# ── Phase: Validate (PoC generation + screenshot evidence) ───
# Reads findings/nuclei.jsonl, generates exploit payloads via Claude Opus,
# captures screenshots via the capture-screenshot helper, and emits an
# evidence/manifest.json that phase_report consumes.
phase_validate_help() {
  cat <<'EOF'
harbinger validate — generate PoC evidence for nuclei findings

Usage:
  harbinger validate <target>
  harbinger phase_validate <target>      (alias)

Reads ${HARBINGER_DIR}/targets/<target>/findings/nuclei.jsonl, filters by severity
(NUCLEI_SEVERITY, default medium,high,critical), and for each finding:
  1. Asks Claude Opus for a minimal proof-of-concept JSON (curl + steps + confidence).
     Falls back to nuclei's own curl-command if the AI call fails.
  2. Captures a full-page Chromium screenshot of the matched URL via the
     capture-screenshot helper. Retries once at 60s on transient timeouts.
  3. Appends a manifest entry under evidence/manifest.json.

Outputs (under ${HARBINGER_DIR}/targets/<target>/evidence/):
  manifest.json         per-finding metadata for phase_report consumption
  payloads/<id>.json    AI-generated or fallback PoC payloads
  screenshots/<id>.png  full-page browser screenshots
  ../logs/validate.log  execution log

Tunables:
  HARBINGER_VALIDATE_LIMIT     max findings to process (default 10)
  HARBINGER_VALIDATE_TIMEOUT   per-screenshot timeout seconds (default 30)
  NUCLEI_SEVERITY              comma list of severities to keep
  HARBINGER_BEST_MODEL         Claude model for payload generation (default opus)
EOF
}

phase_validate() {
  local target="$1"
  if [[ "$target" == "-h" || "$target" == "--help" || "$target" == "help" ]]; then
    phase_validate_help
    exit 0
  fi
  local workspace="${HARBINGER_DIR}/targets/${target}"

  if [[ ! -d "$workspace" ]]; then
    err "No workspace for ${target}. Run: harbinger scan ${target}"
    exit 1
  fi

  local nuclei_file="${workspace}/findings/nuclei.jsonl"
  if [[ ! -s "$nuclei_file" ]]; then
    warn "No nuclei findings at ${nuclei_file} — run: harbinger scan ${target}"
    exit 0
  fi

  local capture="${HARBINGER_BIN}/capture-screenshot"
  if [[ ! -x "$capture" ]]; then
    err "capture-screenshot helper missing or not executable: ${capture}"
    exit 1
  fi

  info "Phase: VALIDATE — ${target}"

  local evidence="${workspace}/evidence"
  mkdir -p "${evidence}/screenshots" "${evidence}/payloads" "${workspace}/logs"

  local logfile="${workspace}/logs/validate.log"
  {
    echo "[$(date -Iseconds)] === validate run start ==="
    echo "  target=${target}  limit=${HARBINGER_VALIDATE_LIMIT}  timeout=${HARBINGER_VALIDATE_TIMEOUT}s  severity=${NUCLEI_SEVERITY}"
  } >> "$logfile"

  local severity_re
  severity_re="^($(echo "$NUCLEI_SEVERITY" | tr ',' '|'))$"

  local manifest_tmp="${evidence}/.manifest.tmp"
  local manifest="${evidence}/manifest.json"

  jq -n \
    --arg target "$target" \
    --arg generated "$(date -Iseconds)" \
    '{target:$target, generated_at:$generated, findings:[]}' \
    > "$manifest_tmp"

  local processed=0 captured=0 ai_ok=0 ai_fb=0 skipped=0

  # AI system prompt — high-leverage knob. Tuned for terse, defensive PoCs.
  local sys_prompt
  sys_prompt='You are a senior bug bounty hunter writing a minimal proof-of-concept for a vulnerability detected by Nuclei.

Output ONLY valid JSON with this shape:
{
  "vulnerability_class": "<short class, e.g. SQLi, SSRF, XSS, IDOR, CVE-XXXX-YYYY>",
  "summary": "<one-sentence impact statement>",
  "curl": "<single-line curl command demonstrating the bug, no shell variables>",
  "expected_response": "<status code, body fragment, header, or behavior that proves the bug>",
  "steps": ["<step 1>", "<step 2>"],
  "confidence": "low|medium|high"
}

Constraints:
- No destructive payloads (no DROP TABLE, rm -rf, fork bombs, mass account takeover).
- Stay on the matched URL host. No lateral targets.
- If unsure, lower confidence rather than fabricate. An empty steps array is acceptable.
- No prose outside the JSON object.'

  # Read findings on FD 3 so child processes (ai, capture-screenshot) can't
  # consume our loop's stdin via `cat`-on-non-tty behavior in invoke-claude.
  while IFS= read -r line <&3; do
    [[ -n "$line" ]] || continue
    if (( processed >= HARBINGER_VALIDATE_LIMIT )); then
      warn "Reached HARBINGER_VALIDATE_LIMIT=${HARBINGER_VALIDATE_LIMIT} — stopping"
      break
    fi

    local sev
    sev=$(echo "$line" | jq -r '."info"?.severity? // empty' 2>/dev/null) || { skipped=$((skipped+1)); continue; }
    if [[ -z "$sev" ]] || [[ ! "$sev" =~ $severity_re ]]; then
      skipped=$((skipped+1)); continue
    fi

    local tmpl matched_at desc curl_cmd
    tmpl=$(echo "$line" | jq -r '."template-id" // empty')
    matched_at=$(echo "$line" | jq -r '."matched-at" // empty')
    desc=$(echo "$line" | jq -r '."info"?.description? // ""')
    curl_cmd=$(echo "$line" | jq -r '."curl-command" // ""')

    if [[ -z "$tmpl" ]] || [[ -z "$matched_at" ]]; then
      skipped=$((skipped+1)); continue
    fi

    case "$matched_at" in
      http://*|https://*) ;;
      *) skipped=$((skipped+1)); continue ;;
    esac

    processed=$((processed+1))

    local id_hash fid
    id_hash=$(printf '%s' "${tmpl}|${matched_at}" | md5sum | cut -c1-10)
    fid=$(printf '%s' "${tmpl}-${id_hash}" | tr -c 'A-Za-z0-9_.-' '_' | cut -c1-80)

    info "  [${processed}] ${sev} ${tmpl} → ${matched_at}"

    local payload_path="${evidence}/payloads/${fid}.json"
    local ai_input ai_out
    ai_input=$(jq -n \
      --arg tmpl "$tmpl" --arg sev "$sev" --arg url "$matched_at" \
      --arg desc "$desc" --arg curl "$curl_cmd" \
      '{template_id:$tmpl, severity:$sev, matched_at:$url, description:$desc, nuclei_curl:$curl}')

    local ai_status=0
    ai_out=$(ai best -s "$sys_prompt" "$ai_input" 2>/dev/null) || ai_status=$?
    if [[ $ai_status -eq 0 ]] && [[ -n "$ai_out" ]] && echo "$ai_out" | jq empty 2>/dev/null; then
      jq -n \
        --arg id "$fid" --arg tmpl "$tmpl" --arg sev "$sev" --arg url "$matched_at" \
        --arg desc "$desc" --arg curl "$curl_cmd" --arg ts "$(date -Iseconds)" \
        --argjson payload "$ai_out" \
        '{id:$id, template_id:$tmpl, severity:$sev, matched_at:$url, description:$desc, nuclei_curl:$curl, payload:$payload, generated_at:$ts, source:"ai"}' \
        > "$payload_path"
      ai_ok=$((ai_ok+1))
    else
      warn "    AI payload failed — falling back to nuclei curl-command"
      jq -n \
        --arg id "$fid" --arg tmpl "$tmpl" --arg sev "$sev" --arg url "$matched_at" \
        --arg desc "$desc" --arg curl "$curl_cmd" --arg ts "$(date -Iseconds)" \
        '{id:$id, template_id:$tmpl, severity:$sev, matched_at:$url, description:$desc, nuclei_curl:$curl, payload:{curl:$curl, summary:"AI generation failed; using nuclei curl-command verbatim"}, generated_at:$ts, source:"fallback"}' \
        > "$payload_path"
      ai_fb=$((ai_fb+1))
    fi

    local shot_path="${evidence}/screenshots/${fid}.png"
    local cap_status=0 cap_out="" reason="" shot_status=""

    cap_out=$("$capture" "$matched_at" "$shot_path" --timeout "$HARBINGER_VALIDATE_TIMEOUT" 2>&1) || cap_status=$?
    echo "[$(date -Iseconds)] capture id=${fid} timeout=${HARBINGER_VALIDATE_TIMEOUT}s exit=${cap_status} ${cap_out}" >> "$logfile"

    # Retry once with 60s timeout on transient runtime failures only;
    # env errors (browser_missing, playwright_missing) and input errors won't fix themselves.
    if [[ $cap_status -ne 0 ]] || [[ ! -s "$shot_path" ]]; then
      reason=$(printf '%s' "$cap_out" | tail -n1 | jq -r '.reason // empty' 2>/dev/null || true)
      case "$reason" in
        page_timeout|navigation_failed|screenshot_failed)
          warn "    screenshot ${reason} — retrying with 60s timeout"
          cap_status=0
          cap_out=$("$capture" "$matched_at" "$shot_path" --timeout 60 2>&1) || cap_status=$?
          echo "[$(date -Iseconds)] capture id=${fid} timeout=60s exit=${cap_status} ${cap_out} (retry)" >> "$logfile"
          ;;
      esac
    fi

    if [[ $cap_status -eq 0 ]] && [[ -s "$shot_path" ]]; then
      captured=$((captured+1))
      shot_status="ok"
    else
      warn "    screenshot failed: ${cap_out}"
      shot_status="failed"
    fi

    jq \
      --arg id "$fid" --arg sev "$sev" --arg status "$shot_status" \
      --arg shot "evidence/screenshots/${fid}.png" \
      --arg payload "evidence/payloads/${fid}.json" \
      --arg matched "$matched_at" --arg tmpl "$tmpl" \
      --arg ts "$(date -Iseconds)" \
      '.findings += [{
         id:$id, template_id:$tmpl, severity:$sev,
         status:$status, screenshot:$shot, payload:$payload,
         matched_at:$matched, timestamp:$ts
       }]' \
      "$manifest_tmp" > "${manifest_tmp}.swap" && mv "${manifest_tmp}.swap" "$manifest_tmp"

  done 3< "$nuclei_file"

  mv "$manifest_tmp" "$manifest"

  if (( processed == 0 )); then
    warn "No findings matched severity filter '${NUCLEI_SEVERITY}' — empty manifest written"
  fi

  echo "[$(date -Iseconds)] === run end: processed=${processed} captured=${captured} ai_ok=${ai_ok} ai_fb=${ai_fb} skipped=${skipped} ===" >> "$logfile"

  local target_meta="${workspace}/target.json"
  if [[ -f "$target_meta" ]]; then
    jq '.phases_completed |= (. + ["validate"] | unique)' "$target_meta" \
      > "${target_meta}.tmp" && mv "${target_meta}.tmp" "$target_meta"
  fi

  ok "Validate — ${processed} processed, ${captured} screenshots, ${ai_ok} AI payloads, ${ai_fb} fallbacks, ${skipped} skipped"
  log "Manifest: ${manifest}"
}

# ── Phase: Hunt (full pipeline) ──────────────────────────────
phase_hunt() {
  local target="$1"

  echo -e "${BOLD}${CYAN}"
  echo "  ╦ ╦┌─┐┬─┐┌┐ ┬┌┐┌┌─┐┌─┐┬─┐"
  echo "  ╠═╣├─┤├┬┘├┴┐││││├┤ ├┤ ├┬┘"
  echo "  ╩ ╩┴ ┴┴└─└─┘┴┘└┘└─┘└─┘┴└─"
  echo -e "${NC}"
  echo -e "  ${DIM}Autonomous Bug Bounty Pipeline${NC}"
  echo -e "  ${DIM}Target: ${target}${NC}"
  echo ""

  phase_recon "$target"
  echo ""
  phase_scan "$target"
  echo ""
  phase_report "$target"

  echo ""
  ok "Hunt complete for ${target}"
  log "Workspace: ${HARBINGER_DIR}/targets/${target}"
}

# ── Status ───────────────────────────────────────────────────
show_status() {
  echo -e "${BOLD}Harbinger Status${NC}"
  echo ""

  # Check AI backends
  echo -e "${BOLD}AI Backends:${NC}"
  if [[ -n "${ANTHROPIC_API_KEY:-${CLAUDE_API_KEY:-}}" ]]; then
    ok "Claude: API key set"
  else
    warn "Claude: No API key (set ANTHROPIC_API_KEY)"
  fi

  if curl -sS "${OLLAMA_HOST_DEFAULT}/api/tags" >/dev/null 2>&1; then
    local models
    models=$(curl -sS "${OLLAMA_HOST_DEFAULT}/api/tags" | jq -r '.models[].name' | tr '\n' ', ' | sed 's/,$//')
    ok "Ollama: running (${models:-no models})"
  else
    warn "Ollama: not running"
  fi

  echo ""
  echo -e "${BOLD}Tools:${NC}"
  for tool in nuclei subfinder httpx katana dalfox ffuf nmap waybackurls gau arjun; do
    if command -v "$tool" &>/dev/null; then
      printf "  ${GREEN}✓${NC} %-15s" "$tool"
    else
      printf "  ${RED}✗${NC} %-15s" "$tool"
    fi
  done
  echo ""

  echo ""
  echo -e "${BOLD}Targets:${NC}"
  if [[ -d "${HARBINGER_DIR}/targets" ]]; then
    for t in "${HARBINGER_DIR}/targets"/*/; do
      [[ -d "$t" ]] || continue
      local name
      name=$(basename "$t")
      local phases
      phases=$(jq -r '.phases_completed | join(", ")' "${t}/target.json" 2>/dev/null || echo "?")
      echo "  ${name}: ${phases}"
    done
  else
    echo "  (none — run: harbinger hunt target.com)"
  fi
}

# ── Patterns (Fabric-style prompt library) ───────────────────
HARBINGER_PATTERNS_DIR="${HARBINGER_PATTERNS_DIR:-$(cd "$HARBINGER_BIN/.." && pwd)/patterns}"
HARBINGER_RUNS_DIR="${HARBINGER_RUNS_DIR:-${HARBINGER_DIR}/runs}"

# Validate raw AI output against a pattern's schema.json. On failure, append
# a structured entry to the run's suppression.jsonl. Always returns 0 — in
# Phase 1 of harbinger doctor we observe but don't suppress; the raw output
# still flows to stdout so existing pipelines are unaffected. Strict mode
# (suppress on schema failure) is a Phase 2 follow-up.
#
# Args: <pattern_name> <schema_path> <raw_output> <run_id>
validate_and_log_suppression() {
  local pattern="$1" schema="$2" raw="$3" run_id="$4"
  local run_dir="${HARBINGER_RUNS_DIR}/${run_id}"
  mkdir -p "$run_dir"
  local sup_log="${run_dir}/suppression.jsonl"
  local meta="${run_dir}/meta.json"

  if [[ ! -f "$meta" ]]; then
    jq -n --arg p "$pattern" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      '{pattern:$p, started_at:$ts}' > "$meta"
  fi

  # Capture stderr (where validate-schema emits the diagnostic JSON) while
  # discarding stdout (validate-schema is silent on stdout). Order matters:
  # `2>&1 >/dev/null` first dups stderr to current stdout (captured by $()),
  # then redirects stdout to /dev/null.
  local err
  err=$(printf '%s' "$raw" | "$HARBINGER_BIN/validate-schema" "$schema" 2>&1 >/dev/null) && return 0

  jq -n \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg pattern "$pattern" \
    --arg raw "$raw" \
    --argjson detail "$err" \
    '{ts:$ts, pattern:$pattern, raw_output:$raw, detail:$detail}' \
    >> "$sup_log"
  return 0
}

# Generate a run-id of the form <UTC ISO compact>-<pattern>. Stable across a
# single run_pattern invocation.
mk_run_id() {
  printf '%s-%s' "$(date -u +%Y%m%dT%H%M%SZ)" "$1"
}

list_patterns() {
  if [[ ! -d "$HARBINGER_PATTERNS_DIR" ]]; then
    err "No patterns dir: $HARBINGER_PATTERNS_DIR"
    exit 1
  fi
  local verbose=false
  if [[ "${1:-}" == "-v" || "${1:-}" == "--verbose" ]]; then
    verbose=true
  fi
  for p in "$HARBINGER_PATTERNS_DIR"/*/; do
    [[ -d "$p" ]] || continue
    local name
    name=$(basename "$p")
    if $verbose; then
      local has_schema="-" has_example="-"
      [[ -f "$p/schema.json" ]] && has_schema="schema"
      [[ -f "$p/examples/example.output.json" ]] && has_example="example"
      printf "%-30s %s %s\n" "$name" "$has_schema" "$has_example"
    else
      echo "$name"
    fi
  done
}

run_pattern() {
  local name="$1"
  shift || true
  local pattern_file="$HARBINGER_PATTERNS_DIR/$name/system.md"
  if [[ ! -f "$pattern_file" ]]; then
    err "Pattern not found: $name"
    echo "Available:" >&2
    list_patterns >&2
    exit 1
  fi
  local system_prompt
  system_prompt=$(cat "$pattern_file")

  # Read input from stdin or remaining args
  local user_input=""
  if [[ ! -t 0 ]]; then
    user_input=$(cat)
  else
    user_input="$*"
  fi
  if [[ -z "$user_input" ]]; then
    err "No input. Usage: harbinger pattern $name <text> OR  echo data | harbinger pattern $name"
    exit 1
  fi

  # Route: JSON-shaped patterns → deep (Claude), others → fast (Ollama)
  local tier="deep"
  case "$name" in
    extract_endpoints|triage_nuclei) tier="fast" ;;
    write_report) tier="best" ;;
  esac

  # If the pattern declares a schema, validate the AI output against it and
  # log any rejection to the run's suppression log so `harbinger doctor` can
  # explain it. Output is still passed through to stdout — Phase 1 observes
  # but does not suppress. Patterns without schema.json bypass entirely.
  local schema_path="$HARBINGER_PATTERNS_DIR/$name/schema.json"
  if [[ -f "$schema_path" ]]; then
    local raw_output run_id
    raw_output=$(ai "$tier" -s "$system_prompt" "$user_input")
    run_id=$(mk_run_id "$name")
    validate_and_log_suppression "$name" "$schema_path" "$raw_output" "$run_id"
    printf '%s\n' "$raw_output"
  else
    ai "$tier" -s "$system_prompt" "$user_input"
  fi
}

# ── harbinger doctor — explain schema validation suppressions ────
#
# Without args: lists recent runs with suppression counts.
# With <run-id> or 'latest': prints all suppressions for that run with the
# raw output and the validator error class so a hunter can decide whether
# to retune the pattern, the schema, or the model.
cmd_doctor() {
  local arg="${1:-}"

  if [[ ! -d "$HARBINGER_RUNS_DIR" ]]; then
    info "No runs found under $HARBINGER_RUNS_DIR"
    return 0
  fi

  if [[ -z "$arg" ]]; then
    echo
    echo "Recent harbinger runs (most recent first):"
    echo
    local found=0
    while IFS= read -r run_id; do
      [[ -z "$run_id" ]] && continue
      found=1
      local sup="${HARBINGER_RUNS_DIR}/${run_id}/suppression.jsonl"
      local count=0
      [[ -f "$sup" ]] && count=$(wc -l < "$sup" | tr -d ' ')
      printf "  %-44s  %s suppression(s)\n" "$run_id" "$count"
    done < <(ls -1t "$HARBINGER_RUNS_DIR" 2>/dev/null | head -20)
    [[ "$found" -eq 0 ]] && echo "  (no runs yet — run a pattern with a schema to populate)"
    echo
    echo "View details with: harbinger doctor <run-id>   (or 'latest')"
    return 0
  fi

  local target_run="$arg"
  if [[ "$arg" == "latest" ]]; then
    target_run=$(ls -1t "$HARBINGER_RUNS_DIR" 2>/dev/null | head -1)
    if [[ -z "$target_run" ]]; then
      err "no runs found"
      return 1
    fi
  fi

  local run_dir="${HARBINGER_RUNS_DIR}/${target_run}"
  if [[ ! -d "$run_dir" ]]; then
    err "run not found: $target_run"
    echo "  expected at: $run_dir" >&2
    return 1
  fi

  local sup="${run_dir}/suppression.jsonl"
  if [[ ! -s "$sup" ]]; then
    info "Run ${target_run}: 0 suppressions (everything passed validation)"
    return 0
  fi

  local total
  total=$(wc -l < "$sup" | tr -d ' ')
  echo
  echo "=== harbinger doctor — run ${target_run} ==="
  echo "Suppressions: ${total}"
  echo
  echo "Grouped by error class:"
  jq -r '.detail.error_class' "$sup" | sort | uniq -c | sort -rn | sed 's/^/  /'
  echo
  echo "Details:"
  echo "--------"
  jq -r '
    "[\(.ts)] pattern=\(.pattern)\n" +
    "  error_class : \(.detail.error_class)\n" +
    "  message     : \(.detail.message)\n" +
    "  json_path   : \(.detail.path | tostring)\n" +
    "  validator   : \(.detail.validator // "n/a")\n" +
    (if (.detail.additional_error_count // 0) > 0
       then "  (\(.detail.additional_error_count) more errors in same output)\n"
       else "" end) +
    "  raw output  :\n" +
    (.raw_output | gsub("(?m)^"; "    "))
  ' "$sup"
  return 0
}

# ── Main ─────────────────────────────────────────────────────
usage() {
  cat <<'EOF'
harbinger — Autonomous Bug Bounty Pipeline

Commands:
  hunt <target>      Full pipeline: recon → scan → report
  recon <target>     Enumerate subdomains, probe hosts, crawl URLs
  scan <target>      Run nuclei + parameter discovery
  analyze <file>     AI-analyze a request/response file
  validate <target>  Generate PoC payloads + screenshots for nuclei findings
  report <target>    Generate report from findings
  doctor [run-id]    Explain schema-suppressed AI outputs (use 'latest' for last)
  pattern <name>     Run a Fabric-style prompt pattern on stdin/args
  pattern list       List available patterns
  patterns list      List available patterns (alias; -v for schema/example status)
  patterns run <n>   Run pattern <n> on stdin/args
  status             Show backends, tools, and targets

AI Routing:
  fast tasks (recon triage, parsing)  → Ollama (local, free)
  deep tasks (vuln analysis)          → Claude Sonnet
  best tasks (report writing)         → Claude Opus

Environment:
  ANTHROPIC_API_KEY    Claude API key
  OLLAMA_HOST          Ollama endpoint (default: http://localhost:11434)
  OLLAMA_MODEL         Default Ollama model (default: llama3.1)
  HARBINGER_DIR        Workspace root (default: ~/.harbinger)
EOF
  exit 0
}

case "${1:-}" in
  hunt)     phase_hunt "${2:?Usage: harbinger hunt <target>}" ;;
  recon)    phase_recon "${2:?Usage: harbinger recon <target>}" ;;
  scan)     phase_scan "${2:?Usage: harbinger scan <target>}" ;;
  analyze)  phase_analyze "${2:?Usage: harbinger analyze <file|text>}" ;;
  validate|phase_validate) phase_validate "${2:?Usage: harbinger validate <target>}" ;;
  report)   phase_report "${2:?Usage: harbinger report <target>}" ;;
  doctor)   cmd_doctor "${@:2}" ;;
  status)   show_status ;;
  pattern)
    case "${2:-}" in
      ""|list) list_patterns "${@:3}" ;;
      *)       run_pattern "$2" "${@:3}" ;;
    esac
    ;;
  patterns)
    case "${2:-}" in
      ""|list) list_patterns "${@:3}" ;;
      run)     run_pattern "${3:?Usage: harbinger patterns run <name> [input]}" "${@:4}" ;;
      *)       run_pattern "$2" "${@:3}" ;;
    esac
    ;;
  -h|--help|help|"") usage ;;
  *)        err "Unknown command: $1"; usage ;;
esac
