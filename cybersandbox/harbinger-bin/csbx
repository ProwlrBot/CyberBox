#!/usr/bin/env bash
# csbx — CyberSandbox plugin manager
# Homebrew-tap style: plugins are git repos with a csbx.yaml manifest
# Registry is a single YAML file in a GitHub repo
set -euo pipefail

# ── Config ───────────────────────────────────────────────────
CSBX_HOME="${CSBX_HOME:-$HOME/.csbx}"
CSBX_BIN="${CSBX_HOME}/bin"
CSBX_PLUGINS="${CSBX_HOME}/plugins"
CSBX_WORDLISTS="${CSBX_PLUGINS}/wordlists"
CSBX_TEMPLATES="${CSBX_PLUGINS}/nuclei-templates"
CSBX_REGISTRY_URL="${CSBX_REGISTRY_URL:-https://raw.githubusercontent.com/ProwlrBot/csbx-registry/main/registry.yaml}"
CSBX_REGISTRY="${CSBX_HOME}/registry.yaml"
CSBX_INSTALLED="${CSBX_HOME}/installed.yaml"

# ── Colors ───────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; DIM='\033[0;90m'
BOLD='\033[1m'; NC='\033[0m'

info()  { echo -e "${CYAN}[+]${NC} $*"; }
ok()    { echo -e "${GREEN}[✓]${NC} $*"; }
warn()  { echo -e "${YELLOW}[!]${NC} $*"; }
err()   { echo -e "${RED}[x]${NC} $*" >&2; }

# ── Init ─────────────────────────────────────────────────────
ensure_dirs() {
  mkdir -p "$CSBX_BIN" "$CSBX_PLUGINS"/{tools,wordlists,nuclei-templates,themes,configs}
  [[ -f "$CSBX_INSTALLED" ]] || echo "plugins: {}" > "$CSBX_INSTALLED"

  # Ensure bin is on PATH
  if [[ ":$PATH:" != *":$CSBX_BIN:"* ]]; then
    export PATH="$CSBX_BIN:$PATH"
  fi
}

# ── YAML helpers (no yq dependency — pure bash for basics) ───
# For complex YAML we fall back to python3 if available
yaml_get() {
  local file="$1" key="$2"
  if command -v python3 &>/dev/null; then
    python3 -c "
import yaml, sys
with open('$file') as f:
    d = yaml.safe_load(f)
keys = '$key'.split('.')
for k in keys:
    if d is None: break
    d = d.get(k) if isinstance(d, dict) else None
print(d if d is not None else '')
" 2>/dev/null
  else
    grep "^  *${key}:" "$file" 2>/dev/null | head -1 | sed 's/.*: *//' | tr -d '"'
  fi
}

yaml_get_block() {
  local file="$1" key="$2"
  python3 -c "
import yaml
with open('$file') as f:
    d = yaml.safe_load(f)
keys = '$key'.split('.')
for k in keys:
    if d is None: break
    d = d.get(k) if isinstance(d, dict) else None
if d: print(d)
" 2>/dev/null || echo ""
}

yaml_list() {
  local file="$1" key="$2"
  python3 -c "
import yaml
with open('$file') as f:
    d = yaml.safe_load(f)
keys = '$key'.split('.')
for k in keys:
    if d is None: break
    d = d.get(k) if isinstance(d, dict) else None
if isinstance(d, list):
    for item in d: print(item)
" 2>/dev/null
}

# ── Registry ─────────────────────────────────────────────────
registry_sync() {
  info "Syncing registry..."
  if curl -fsSL "$CSBX_REGISTRY_URL" -o "${CSBX_REGISTRY}.tmp" 2>/dev/null; then
    mv "${CSBX_REGISTRY}.tmp" "$CSBX_REGISTRY"
    ok "Registry synced"
  else
    warn "Failed to fetch registry — using cached copy"
    # Create a minimal registry if none exists
    if [[ ! -f "$CSBX_REGISTRY" ]]; then
      cat > "$CSBX_REGISTRY" <<'YAML'
version: 1
plugins:
  seclists:
    repo: https://github.com/danielmiessler/SecLists
    type: wordlist
    description: "Discovery, fuzzing, and password lists"
    size: "1.2GB"
    tags: [recon, fuzzing, passwords]
  nuclei-templates:
    repo: https://github.com/projectdiscovery/nuclei-templates
    type: nuclei-templates
    description: "Official ProjectDiscovery nuclei templates"
    size: "180MB"
    tags: [scanning, cves]
  powerlevel10k:
    repo: https://github.com/romkatv/powerlevel10k
    type: theme
    description: "Zsh theme with instant prompt"
    size: "4MB"
    tags: [shell, theme, zsh]
  fuzzdb:
    repo: https://github.com/fuzzdb-project/fuzzdb
    type: wordlist
    description: "Attack patterns and payload lists"
    size: "60MB"
    tags: [fuzzing, payloads]
  onelistforall:
    repo: https://github.com/six2dez/OneListForAll
    type: wordlist
    description: "Merged wordlists for web fuzzing"
    size: "500MB"
    tags: [fuzzing, discovery]
  payloadsallthethings:
    repo: https://github.com/swisskyrepo/PayloadsAllTheThings
    type: wordlist
    description: "Payload lists for web app security"
    size: "200MB"
    tags: [payloads, injection, xss, sqli]
  assetnote-wordlists:
    repo: https://github.com/assetnote/wordlists
    type: wordlist
    description: "Assetnote automated wordlists"
    size: "2GB"
    tags: [recon, fuzzing, subdomains]
  gf-patterns:
    repo: https://github.com/1ndianl33t/Gf-Patterns
    type: config
    description: "GF patterns for bug bounty"
    size: "50KB"
    tags: [recon, patterns, gf]
  zsh-autosuggestions:
    repo: https://github.com/zsh-users/zsh-autosuggestions
    type: theme
    description: "Fish-like autosuggestions for zsh"
    size: "200KB"
    tags: [shell, zsh]
  zsh-syntax-highlighting:
    repo: https://github.com/zsh-users/zsh-syntax-highlighting
    type: theme
    description: "Syntax highlighting for zsh"
    size: "500KB"
    tags: [shell, zsh]
YAML
      ok "Created default registry"
    fi
  fi
}

# ── Search ───────────────────────────────────────────────────
cmd_search() {
  local query="${1:-}"
  [[ ! -f "$CSBX_REGISTRY" ]] && registry_sync

  python3 -c "
import yaml
with open('$CSBX_REGISTRY') as f:
    reg = yaml.safe_load(f)
query = '$query'.lower()
for name, info in sorted(reg.get('plugins', {}).items()):
    searchable = f\"{name} {info.get('description','')} {' '.join(info.get('tags',[]))}\".lower()
    if not query or query in searchable:
        typ = info.get('type','?')
        desc = info.get('description','')[:60]
        size = info.get('size','?')
        print(f'  \033[1m{name:25s}\033[0m {typ:20s} {size:>8s}  {desc}')
" 2>/dev/null
}

# ── Info ─────────────────────────────────────────────────────
cmd_info() {
  local name="$1"
  [[ ! -f "$CSBX_REGISTRY" ]] && registry_sync

  python3 -c "
import yaml
with open('$CSBX_REGISTRY') as f:
    reg = yaml.safe_load(f)
p = reg.get('plugins', {}).get('$name')
if not p:
    print('\033[31m[x]\033[0m Plugin \"$name\" not in registry')
else:
    print(f\"\033[1m{' $name '}\033[0m\")
    print(f\"  Type:        {p.get('type','?')}\")
    print(f\"  Description: {p.get('description','?')}\")
    print(f\"  Repo:        {p.get('repo','?')}\")
    print(f\"  Size:        {p.get('size','?')}\")
    print(f\"  Tags:        {', '.join(p.get('tags',[]))}\")

    # Check if installed
    import os
    installed_file = '$CSBX_INSTALLED'
    if os.path.exists(installed_file):
        with open(installed_file) as f2:
            inst = yaml.safe_load(f2)
        if '$name' in inst.get('plugins', {}):
            i = inst['plugins']['$name']
            print(f\"  \033[32mInstalled:\033[0m {i.get('installed_at','?')} at {i.get('path','?')}\")
        else:
            print(f\"  \033[33mNot installed\033[0m\")
" 2>/dev/null
}

# ── Install ──────────────────────────────────────────────────
cmd_install() {
  local input="$1"
  local name="" repo_url="" plugin_type=""

  # Determine if input is a name (from registry) or a URL
  if [[ "$input" == http* || "$input" == git@* ]]; then
    repo_url="$input"
    name=$(basename "$repo_url" .git)
    warn "Installing unregistered plugin — review csbx.yaml before trusting"
  else
    name="$input"
    [[ ! -f "$CSBX_REGISTRY" ]] && registry_sync
    repo_url=$(yaml_get "$CSBX_REGISTRY" "plugins.${name}.repo")
    if [[ -z "$repo_url" ]]; then
      err "Plugin \"${name}\" not found in registry"
      echo "  Try: csbx search ${name}"
      echo "  Or:  csbx install https://github.com/user/repo"
      return 1
    fi
    plugin_type=$(yaml_get "$CSBX_REGISTRY" "plugins.${name}.type")
  fi

  # Check if already installed
  if [[ -f "$CSBX_INSTALLED" ]] && python3 -c "
import yaml
with open('$CSBX_INSTALLED') as f:
    d = yaml.safe_load(f)
exit(0 if '$name' in d.get('plugins',{}) else 1)
" 2>/dev/null; then
    warn "${name} already installed. Use: csbx update ${name}"
    return 0
  fi

  info "Installing ${name} from ${repo_url}..."

  # Clone (shallow)
  local tmp_dir
  tmp_dir=$(mktemp -d)
  if ! git clone --depth 1 "$repo_url" "$tmp_dir" 2>/dev/null; then
    err "Failed to clone ${repo_url}"
    rm -rf "$tmp_dir"
    return 1
  fi

  # Read manifest if present
  local manifest="${tmp_dir}/csbx.yaml"
  if [[ -f "$manifest" ]]; then
    plugin_type=$(yaml_get "$manifest" "type")
  fi
  plugin_type="${plugin_type:-tool}"

  # Move to final location
  local target_dir="${CSBX_PLUGINS}/${plugin_type}/${name}"
  mkdir -p "$(dirname "$target_dir")"
  [[ -d "$target_dir" ]] && rm -rf "$target_dir"
  mv "$tmp_dir" "$target_dir"

  # Run install hook
  if [[ -f "${target_dir}/csbx.yaml" ]]; then
    local install_script
    install_script=$(yaml_get_block "${target_dir}/csbx.yaml" "install")
    if [[ -n "$install_script" && "$install_script" != "None" ]]; then
      info "Running install hook..."
      export CSBX_PLUGIN_DIR="$target_dir"
      export CSBX_WORDLISTS CSBX_TEMPLATES CSBX_BIN
      (cd "$target_dir" && bash -c "$install_script") || warn "Install hook had errors"
    fi

    # Symlink binaries
    while IFS= read -r bin; do
      [[ -z "$bin" ]] && continue
      ln -sf "${target_dir}/${bin}" "${CSBX_BIN}/$(basename "$bin")"
      ok "Linked: $(basename "$bin")"
    done < <(yaml_list "${target_dir}/csbx.yaml" "binaries")

    # Post-install hook
    local post_script
    post_script=$(yaml_get_block "${target_dir}/csbx.yaml" "post_install")
    if [[ -n "$post_script" && "$post_script" != "None" ]]; then
      export CSBX_PLUGIN_DIR="$target_dir"
      (cd "$target_dir" && bash -c "$post_script") || true
    fi
  fi

  # Record installation
  python3 -c "
import yaml, datetime
with open('$CSBX_INSTALLED') as f:
    d = yaml.safe_load(f) or {'plugins': {}}
d.setdefault('plugins', {})['$name'] = {
    'type': '$plugin_type',
    'repo': '$repo_url',
    'installed_at': datetime.datetime.now().isoformat(),
    'path': '$target_dir'
}
with open('$CSBX_INSTALLED', 'w') as f:
    yaml.dump(d, f, default_flow_style=False)
" 2>/dev/null

  ok "${name} installed → ${target_dir}"
}

# ── Remove ───────────────────────────────────────────────────
cmd_remove() {
  local name="$1"

  # Find installed path
  local path
  path=$(python3 -c "
import yaml
with open('$CSBX_INSTALLED') as f:
    d = yaml.safe_load(f)
p = d.get('plugins',{}).get('$name',{})
print(p.get('path',''))
" 2>/dev/null)

  if [[ -z "$path" || ! -d "$path" ]]; then
    err "${name} is not installed"
    return 1
  fi

  # Run uninstall hook
  if [[ -f "${path}/csbx.yaml" ]]; then
    local uninstall_script
    uninstall_script=$(yaml_get_block "${path}/csbx.yaml" "uninstall")
    if [[ -n "$uninstall_script" && "$uninstall_script" != "None" ]]; then
      info "Running uninstall hook..."
      export CSBX_PLUGIN_DIR="$path"
      export CSBX_WORDLISTS CSBX_TEMPLATES CSBX_BIN
      (cd "$path" && bash -c "$uninstall_script") || true
    fi

    # Remove binary symlinks
    while IFS= read -r bin; do
      [[ -z "$bin" ]] && continue
      rm -f "${CSBX_BIN}/$(basename "$bin")"
    done < <(yaml_list "${path}/csbx.yaml" "binaries")
  fi

  # Delete plugin directory
  rm -rf "$path"

  # Remove from installed.yaml
  python3 -c "
import yaml
with open('$CSBX_INSTALLED') as f:
    d = yaml.safe_load(f) or {'plugins': {}}
d.get('plugins', {}).pop('$name', None)
with open('$CSBX_INSTALLED', 'w') as f:
    yaml.dump(d, f, default_flow_style=False)
" 2>/dev/null

  ok "${name} removed"
}

# ── Update ───────────────────────────────────────────────────
cmd_update() {
  local name="$1"

  if [[ "$name" == "--all" ]]; then
    python3 -c "
import yaml
with open('$CSBX_INSTALLED') as f:
    d = yaml.safe_load(f)
for name in d.get('plugins', {}):
    print(name)
" 2>/dev/null | while IFS= read -r plugin; do
      cmd_update "$plugin"
    done
    return
  fi

  local path
  path=$(python3 -c "
import yaml
with open('$CSBX_INSTALLED') as f:
    d = yaml.safe_load(f)
print(d.get('plugins',{}).get('$name',{}).get('path',''))
" 2>/dev/null)

  if [[ -z "$path" || ! -d "$path" ]]; then
    err "${name} is not installed"
    return 1
  fi

  info "Updating ${name}..."
  if git -C "$path" pull --ff-only 2>/dev/null; then
    # Re-run install hook if manifest exists
    if [[ -f "${path}/csbx.yaml" ]]; then
      local install_script
      install_script=$(yaml_get_block "${path}/csbx.yaml" "install")
      if [[ -n "$install_script" && "$install_script" != "None" ]]; then
        export CSBX_PLUGIN_DIR="$path"
        (cd "$path" && bash -c "$install_script") || true
      fi
    fi
    ok "${name} updated"
  else
    warn "${name} update failed — try: csbx remove ${name} && csbx install ${name}"
  fi
}

# ── List ─────────────────────────────────────────────────────
cmd_list() {
  if [[ "${1:-}" == "--available" ]]; then
    echo -e "${BOLD}Available plugins:${NC}"
    cmd_search ""
    return
  fi

  echo -e "${BOLD}Installed plugins:${NC}"
  if [[ ! -f "$CSBX_INSTALLED" ]]; then
    echo "  (none)"
    return
  fi

  python3 -c "
import yaml
with open('$CSBX_INSTALLED') as f:
    d = yaml.safe_load(f)
plugins = d.get('plugins', {})
if not plugins:
    print('  (none — try: csbx install seclists)')
for name, info in sorted(plugins.items()):
    typ = info.get('type','?')
    path = info.get('path','?')
    print(f'  \033[1m{name:25s}\033[0m {typ:20s} {path}')
" 2>/dev/null
}

# ── Doctor ───────────────────────────────────────────────────
cmd_doctor() {
  echo -e "${BOLD}CyberSandbox Health Check${NC}"
  echo ""

  # Check dirs
  for dir in "$CSBX_HOME" "$CSBX_BIN" "$CSBX_PLUGINS"; do
    if [[ -d "$dir" ]]; then
      ok "$dir"
    else
      warn "$dir missing"
    fi
  done

  # Check broken symlinks in bin
  local broken=0
  for link in "$CSBX_BIN"/*; do
    [[ -e "$link" ]] && continue
    [[ -L "$link" ]] || continue
    warn "Broken symlink: $link"
    broken=$((broken + 1))
  done
  [[ $broken -eq 0 ]] && ok "No broken symlinks"

  # Check python3 + yaml
  if python3 -c "import yaml" 2>/dev/null; then
    ok "python3 + pyyaml available"
  else
    err "python3 or pyyaml missing — csbx needs it"
    echo "  Fix: pip3 install pyyaml"
  fi

  # Check git
  if command -v git &>/dev/null; then
    ok "git available"
  else
    err "git missing"
  fi

  # Show stats
  echo ""
  local count
  count=$(python3 -c "
import yaml
with open('$CSBX_INSTALLED') as f:
    d = yaml.safe_load(f)
print(len(d.get('plugins',{})))
" 2>/dev/null || echo "0")
  info "${count} plugin(s) installed"

  local size
  size=$(du -sh "$CSBX_PLUGINS" 2>/dev/null | cut -f1)
  info "Plugin storage: ${size:-0}"
}

# ── Main ─────────────────────────────────────────────────────
usage() {
  cat <<'EOF'
csbx — CyberSandbox Plugin Manager

COMMANDS:
  search [query]        Search available plugins
  info <plugin>         Show plugin details
  install <plugin>      Install from registry
  install <git-url>     Install from any git URL
  remove <plugin>       Uninstall a plugin
  update <plugin>       Update a plugin (git pull)
  update --all          Update all plugins
  list                  List installed plugins
  list --available      List all registry plugins
  sync                  Force re-fetch registry
  doctor                Health check

PLUGIN TYPES:
  tool                  Binaries (Go, Rust, Python tools)
  wordlist              Wordlists (SecLists, PayloadsAllTheThings, etc)
  nuclei-templates      Nuclei template collections
  theme                 Shell themes (p10k, zsh plugins)
  config                Config files (gf patterns, etc)

EXAMPLES:
  csbx install seclists
  csbx install payloadsallthethings
  csbx install https://github.com/someone/custom-tool
  csbx search xss
  csbx list
  csbx update --all

ENVIRONMENT:
  CSBX_HOME             Plugin root (default: ~/.csbx)
  CSBX_REGISTRY_URL     Registry URL (default: ProwlrBot/csbx-registry)
EOF
  exit 0
}

ensure_dirs

case "${1:-}" in
  search)   cmd_search "${2:-}" ;;
  info)     cmd_info "${2:?Usage: csbx info <plugin>}" ;;
  install)  cmd_install "${2:?Usage: csbx install <plugin|url>}" ;;
  remove)   cmd_remove "${2:?Usage: csbx remove <plugin>}" ;;
  update)   cmd_update "${2:?Usage: csbx update <plugin|--all>}" ;;
  list)     cmd_list "${2:-}" ;;
  sync)     registry_sync ;;
  doctor)   cmd_doctor ;;
  -h|--help|help|"") usage ;;
  *)        err "Unknown command: $1"; usage ;;
esac
